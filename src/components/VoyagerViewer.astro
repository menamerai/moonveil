---
---

<div class="viewer-wrap">
  <span class="viewer-label">VOYAGER PROBE // MODEL A</span>
  <canvas id="voyager-canvas"></canvas>
  <span class="viewer-hint">DRAG TO ROTATE</span>
</div>

<style>
  .viewer-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 100%;
    height: 100%;
  }

  .viewer-label {
    font-family: var(--f-mono);
    font-size: 8px;
    letter-spacing: 0.26em;
    color: var(--cream-dim);
    align-self: flex-start;
  }

  #voyager-canvas {
    display: block;
    width: 100%;
    flex: 1;
    cursor: grab;
  }

  #voyager-canvas:active {
    cursor: grabbing;
  }

  .viewer-hint {
    font-family: var(--f-mono);
    font-size: 7px;
    letter-spacing: 0.22em;
    color: var(--cream-dim);
    opacity: 0.5;
  }
</style>

<script>
  import * as THREE from "three";
  import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";
  import { OrbitControls } from "three/addons/controls/OrbitControls.js";

  const canvas = document.getElementById("voyager-canvas") as HTMLCanvasElement;
  const wrap = canvas.parentElement as HTMLElement;

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.outputColorSpace = THREE.SRGBColorSpace;

  const scene = new THREE.Scene();

  const camera = new THREE.PerspectiveCamera(42, 1, 0.01, 1000);
  camera.position.set(0, 0.5, 4);

  // Ambient
  scene.add(new THREE.AmbientLight(0xddd3bc, 0.5));

  // Key light — blue, from front-left
  const key = new THREE.DirectionalLight(0x8ec8de, 3.5);
  key.position.set(-2, 2, 3);
  scene.add(key);

  // Rim light — orange, from rear-right
  const rim = new THREE.DirectionalLight(0xc75e26, 1.8);
  rim.position.set(3, -1, -2);
  scene.add(rim);

  // Soft fill
  const fill = new THREE.DirectionalLight(0xddd3bc, 0.4);
  fill.position.set(0, -3, 1);
  scene.add(fill);

  const controls = new OrbitControls(camera, renderer.domElement);
  controls.enableDamping = true;
  controls.dampingFactor = 0.06;
  controls.autoRotate = true;
  controls.autoRotateSpeed = 1.2;
  controls.enablePan = false;
  controls.minDistance = 1.5;
  controls.maxDistance = 10;

  let rotateTimer: ReturnType<typeof setTimeout>;
  controls.addEventListener("start", () => {
    controls.autoRotate = false;
    clearTimeout(rotateTimer);
  });
  controls.addEventListener("end", () => {
    rotateTimer = setTimeout(() => {
      controls.autoRotate = true;
    }, 2500);
  });

  const loader = new GLTFLoader();
  const base = import.meta.env.BASE_URL;

  loader.load(`${base}/models/voyager.glb`, (gltf) => {
    const model = gltf.scene;

    const box = new THREE.Box3().setFromObject(model);
    const center = box.getCenter(new THREE.Vector3());
    const size = box.getSize(new THREE.Vector3());
    model.position.sub(center);
    model.scale.setScalar(2.8 / Math.max(size.x, size.y, size.z));

    scene.add(model);
  });

  function resize() {
    const w = wrap.clientWidth;
    const h = wrap.clientHeight - 60; // subtract label + hint height
    renderer.setSize(w, Math.max(h, 160));
    camera.aspect = w / Math.max(h, 160);
    camera.updateProjectionMatrix();
  }

  resize();
  window.addEventListener("resize", resize);

  function animate() {
    requestAnimationFrame(animate);
    controls.update();
    renderer.render(scene, camera);
  }
  animate();
</script>
