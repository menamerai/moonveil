---
interface Props {
  bordered?: boolean;
}
const { bordered = false } = Astro.props;
---

<footer class={bordered ? "bordered" : ""}>
  <span class="footer-sig">© 2026 PHAN ANH DUONG // ALL SYSTEMS NOMINAL</span>
  <div class="footer-links">
    <a href="https://github.com/menamerai" target="_blank" rel="noopener">GITHUB</a>
    <a href="https://www.linkedin.com/in/phananhduong/" target="_blank" rel="noopener">LINKEDIN</a>
    <a
      href="https://scholar.google.com/citations?user=LSGBjPoAAAAJ&hl=en"
      target="_blank"
      rel="noopener">SCHOLAR</a
    >
  </div>
</footer>

<style>
  footer {
    padding: 36px 52px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  footer.bordered {
    border-top: 1px solid var(--border);
    padding: 32px 52px;
  }

  .footer-sig {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    color: var(--cream-dim);
  }

  .footer-links {
    display: flex;
    gap: 24px;
  }

  .footer-links a {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    color: var(--cream-dim);
    transition: color 0.2s;
  }
  .footer-links a:hover {
    color: var(--cream);
  }

  @media (max-width: 620px) {
    footer,
    footer.bordered {
      padding: 28px 24px;
    }
  }
</style>
