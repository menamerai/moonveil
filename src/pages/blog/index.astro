---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MissionTag from "../../components/MissionTag.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Transmission Log — Phan Anh Duong"
  description="Writing and dispatches from Phan Anh Duong."
  footerBordered={true}
>
  <div class="wrap">
    <div class="page-header">
      <MissionTag text="TRANSMISSION LOG // ALL ENTRIES" />
      <h1 class="page-title">Writing</h1>
      <p class="page-subtitle">DISPATCHES FROM THE FIELD (MY HEAD) — RAI</p>
    </div>

    <div class="filters">
      <span class="filter-label">FILTER //</span>
      <button class="tag-pill active" data-tag="all">ALL</button>
      {
        allTags.map((tag) => (
          <button class="tag-pill" data-tag={tag.toLowerCase()}>
            {tag}
          </button>
        ))
      }
    </div>

    <div class="post-list" id="postList">
      {
        posts.map((post) => (
          <a
            class="post-item"
            href={`${base}/blog/${post.slug}`}
            data-tags={post.data.tags.map((t) => t.toLowerCase()).join(" ")}
          >
            <div class="post-meta-row">
              <span class="post-date">{post.data.date.toISOString().slice(0, 10)}</span>
              <span class="post-author">{post.data.author}</span>
              <div class="post-tags">
                {post.data.tags.map((tag) => (
                  <span class="p-tag">{tag}</span>
                ))}
              </div>
            </div>
            <div class="post-title">{post.data.title}</div>
            <div class="post-desc">{post.data.description}</div>
            <span class="read-more">READ TRANSMISSION →</span>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLElement>(".tag-pill");
  const postItems = document.querySelectorAll<HTMLElement>(".post-item");

  pills.forEach((pill) => {
    pill.addEventListener("click", () => {
      pills.forEach((p) => p.classList.remove("active"));
      pill.classList.add("active");

      const tag = pill.dataset.tag ?? "all";
      postItems.forEach((post) => {
        if (tag === "all") {
          post.style.display = "";
        } else {
          const tags = post.dataset.tags ?? "";
          post.style.display = tags.split(" ").includes(tag) ? "" : "none";
        }
      });
    });
  });
</script>

<style>
  .wrap {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 52px;
  }

  /* ── PAGE HEADER ── */
  .page-header {
    padding: 72px 0 56px;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, var(--cream-dim) 1px, transparent 1px);
    background-size: 26px 26px;
    opacity: 0.12;
    pointer-events: none;
  }

  h1.page-title {
    position: relative;
    font-family: var(--f-display);
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 0.94;
    color: var(--cream);
    margin-bottom: 18px;
  }

  .page-subtitle {
    position: relative;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--cream-dim);
  }

  /* ── FILTERS ── */
  .filters {
    padding: 28px 0;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--cream-dim);
    margin-right: 4px;
  }

  .tag-pill {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    color: var(--cream-dim);
    border: 1px solid var(--border-mid);
    background: none;
    padding: 4px 10px;
    cursor: pointer;
    transition: all 0.15s;
  }

  .tag-pill:hover,
  .tag-pill.active {
    color: var(--blue);
    border-color: var(--blue);
    background: rgba(90, 163, 188, 0.08);
  }

  /* ── POST LIST ── */
  .post-list {
    display: flex;
    flex-direction: column;
    padding: 8px 0 64px;
  }

  .post-item {
    display: block;
    padding: 17px 10px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .post-item:hover {
    background: var(--orange-glow);
  }

  .post-item:hover .post-title {
    color: var(--orange);
  }
  .post-item:hover .read-more {
    opacity: 1;
    transform: translateX(3px);
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 10px;
  }

  .post-date {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--cream-dim);
  }

  .post-author {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    color: var(--cream-dim);
  }

  .post-author::before {
    content: "// ";
    opacity: 0.5;
  }

  .post-tags {
    display: flex;
    gap: 8px;
    margin-left: auto;
  }

  .p-tag {
    font-family: var(--f-mono);
    font-size: 8px;
    letter-spacing: 0.1em;
    color: var(--blue);
    border: 1px solid rgba(90, 163, 188, 0.25);
    padding: 2px 7px;
  }

  .post-title {
    font-family: var(--f-display);
    font-size: 26px;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: 10px;
    transition: color 0.15s;
  }

  .post-desc {
    font-family: var(--f-body);
    font-size: 16px;
    font-style: italic;
    color: var(--cream-mid);
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .read-more {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--orange);
    opacity: 0;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition:
      opacity 0.15s,
      transform 0.15s;
  }

  @media (max-width: 620px) {
    .wrap {
      padding: 0 24px;
    }
    .post-tags {
      display: none;
    }
  }
</style>
