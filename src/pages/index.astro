---
import BaseLayout from "../layouts/BaseLayout.astro";
import MissionTag from "../components/MissionTag.astro";
import SectionHead from "../components/SectionHead.astro";
import OrbitalCanvas from "../components/OrbitalCanvas.astro";
import { papers } from "../data/papers";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection("blog");
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Phan Anh Duong">
  <div class="wrap">
    <!-- HERO -->
    <section class="hero">
      <MissionTag text="PERSONNEL FILE // 001-PAD" />

      <h1 class="name">
        Phan Anh<br />Duong
      </h1>

      <p class="tagline">
        I do AI safety research sometimes.<span class="cursor-block"></span>
      </p>

      <div class="hero-meta">
        <div class="meta-field">
          <span class="meta-key">CALLSIGN</span>
          <span class="meta-val">RAI</span>
        </div>
        <div class="meta-field">
          <span class="meta-key">STATUS</span>
          <span class="meta-val status">ACTIVE</span>
        </div>
        <div class="meta-field">
          <span class="meta-key">ROLE</span>
          <span class="meta-val">SOLUTIONS ARCHITECT</span>
        </div>
        <div class="meta-field">
          <span class="meta-key">AFFILIATION</span>
          <span class="meta-val">NVIDIA</span>
        </div>
        <div class="meta-field">
          <span class="meta-key">DOMAIN</span>
          <span class="meta-val">AI SAFETY</span>
        </div>
      </div>
    </section>

    <!-- RESEARCH OUTPUT -->
    <section class="block">
      <SectionHead label="RESEARCH OUTPUT" num="01" />
      <div class="paper-list">
        {
          [...papers]
            .sort((a, b) => b.year - a.year)
            .map((paper) => (
              <a class="paper-item" href={paper.url} target="_blank" rel="noopener">
                <span class="p-year">{paper.year}</span>
                <span class="paper-title">{paper.title}</span>
                <span class="p-num">{paper.num}</span>
              </a>
            ))
        }
      </div>
    </section>

    <!-- TRANSMISSION LOG -->
    <section class="block">
      <SectionHead label="TRANSMISSION LOG" num="02" />
      <div class="blog-list">
        {
          recentPosts.map((post) => (
            <a class="blog-item" href={`${base}/blog/${post.slug}`}>
              <span class="b-date">{post.data.date.toISOString().slice(0, 10)}</span>
              <span class="b-title">{post.data.title}</span>
              <span class="b-arrow">→</span>
            </a>
          ))
        }
      </div>
      <a class="view-all" href={`${base}/blog`}>VIEW ALL TRANSMISSIONS <span>→</span></a>
    </section>
  </div>

  <!-- ORBITAL VISUALIZATION -->
  <OrbitalCanvas />
</BaseLayout>

<style>
  .wrap {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 52px;
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 88px 0 72px;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, var(--cream-dim) 1px, transparent 1px);
    background-size: 26px 26px;
    opacity: 0.16;
    pointer-events: none;
  }

  h1.name {
    position: relative;
    font-family: var(--f-display);
    font-size: clamp(58px, 9vw, 96px);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--cream);
    margin-bottom: 28px;
  }

  .tagline {
    position: relative;
    font-family: var(--f-body);
    font-style: italic;
    font-weight: 300;
    font-size: 21px;
    color: var(--cream-mid);
    margin-bottom: 52px;
    line-height: 1.4;
  }

  .cursor-block {
    display: inline-block;
    width: 11px;
    height: 19px;
    background: var(--blue);
    margin-left: 4px;
    vertical-align: middle;
    animation: blink 1.15s step-end infinite;
  }

  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  .hero-meta {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 36px;
  }

  .meta-field {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .meta-key {
    font-family: var(--f-mono);
    font-size: 8px;
    letter-spacing: 0.25em;
    color: var(--cream-dim);
  }

  .meta-val {
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--cream);
  }

  .meta-val.status {
    color: var(--blue);
  }
  .meta-val.status::before {
    content: "● ";
    font-size: 7px;
  }

  /* ── SECTION ── */
  section.block {
    padding: 60px 0;
    border-bottom: 1px solid var(--border);
  }

  /* ── PAPERS ── */
  .paper-list {
    display: flex;
    flex-direction: column;
  }

  .paper-item {
    display: grid;
    grid-template-columns: 108px 1fr 38px;
    gap: 24px;
    align-items: baseline;
    padding: 17px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: background 0.15s;
  }

  .paper-item:first-child {
    border-top: 1px solid var(--border);
  }

  .paper-item:hover {
    background: var(--blue-glow);
  }

  .paper-item:hover .paper-title {
    color: var(--blue);
  }

  .p-year {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--cream-dim);
    letter-spacing: 0.04em;
  }

  .paper-title {
    font-family: var(--f-body);
    font-style: italic;
    font-size: 16.5px;
    color: var(--cream);
    line-height: 1.5;
    transition: color 0.15s;
  }

  .p-num {
    font-family: var(--f-mono);
    font-size: 9px;
    color: var(--cream-dim);
    text-align: right;
  }

  /* ── BLOG PREVIEW ── */
  .blog-list {
    display: flex;
    flex-direction: column;
  }

  .blog-item {
    display: grid;
    grid-template-columns: 108px 1fr 20px;
    gap: 24px;
    align-items: baseline;
    padding: 17px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .blog-item:first-child {
    border-top: 1px solid var(--border);
  }

  .blog-item:hover {
    background: var(--orange-glow);
  }

  .blog-item:hover .b-title {
    color: var(--orange);
  }
  .blog-item:hover .b-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  .b-date {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--cream-dim);
    letter-spacing: 0.04em;
  }

  .b-title {
    font-family: var(--f-body);
    font-size: 17px;
    color: var(--cream);
    transition: color 0.15s;
    line-height: 1.4;
  }

  .b-arrow {
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--orange);
    opacity: 0;
    transition:
      opacity 0.15s,
      transform 0.15s;
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 28px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--cream-dim);
    transition: color 0.2s;
  }
  .view-all:hover {
    color: var(--orange);
  }
  .view-all span {
    transition: transform 0.2s;
  }
  .view-all:hover span {
    transform: translateX(4px);
  }

  @media (max-width: 620px) {
    .wrap {
      padding: 0 24px;
    }
    .hero {
      padding: 64px 0 52px;
    }
    .blog-item {
      grid-template-columns: 90px 1fr 18px;
      gap: 14px;
    }
  }
</style>
